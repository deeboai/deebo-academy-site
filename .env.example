# Do not place real values in this file before committing.
# Keep private admin emails, tokens, and secret keys only in local env files or the Netlify/Supabase dashboards.

# Public client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private server configuration
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# Email configuration
# ACADEMY_FROM_EMAIL can be a public-facing mailbox alias.
# ACADEMY_NOTIFICATION_EMAIL should stay private and operational.
ACADEMY_FROM_EMAIL=
ACADEMY_NOTIFICATION_EMAIL=

# Public app URL
NEXT_PUBLIC_ACADEMY_SITE_URL=

# Private payments configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Private calendar automation configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_REFRESH_TOKEN=
